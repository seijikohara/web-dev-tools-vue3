{
  "name": "web-dev-tools-vue3",
  "private": true,
  "description": "Web Development Tools",
  "type": "module",
  "scripts": {
    "prepare": "lefthook install || exit 0",
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "vue-tsc --build --force && vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "build:analyze": "vite build --mode analyze",
    "typecheck": "vue-tsc --build --force",
    "typecheck:watch": "vue-tsc --build --force --watch",
    "lint": "oxlint && eslint 'src/**/*.vue'",
    "lint:fix": "oxlint --fix && eslint 'src/**/*.vue' --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "clean": "rm -rf dist node_modules/.vite node_modules/.tmp",
    "deps:update": "taze -w && pnpm install",
    "deps:check": "taze",
    "ci:check": "pnpm run lint && pnpm run format:check && pnpm run typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen http://localhost:5173",
    "test:e2e:install": "playwright install --with-deps"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.0",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@primeuix/themes": "^2.0.3",
    "@vueuse/core": "^14.2.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "codemirror": "^6.0.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.20",
    "dompurify": "^3.4.5",
    "json-tree-view-vue3": "^1.1.2",
    "marked": "^18.0.0",
    "pinia": "^3.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "qrcode": "^1.5.4",
    "regexp-tree": "^0.1.27",
    "sql-formatter": "^15.7.3",
    "ua-parser-js": "^2.0.9",
    "vue": "^3.5.32",
    "vue-codemirror6": "^1.5.1",
    "vue-gtag": "^3.7.0",
    "vue-router": "^5.0.4",
    "xml-formatter": "^3.7.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tsconfig/node24": "^24.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/ua-parser-js": "^0.7.39",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.0",
    "eslint-plugin-oxlint": "^1.73.0",
    "eslint-plugin-vue": "^10.8.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "sass": "^1.99.0",
    "taze": "^19.14.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.7"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.11.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.11.0"
}
